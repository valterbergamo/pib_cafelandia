# SPA (React Router) no Apache — devolve index.html em qualquer rota,
# para que F5/refresh em /admin/eventos etc. não retorne 404.
#
# Atrás do nginx, o Apache serve este site sob /pib/ (nginx: / -> localhost:5082/pib/),
# por isso o RewriteBase é /pib/.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /pib/

  # Se o caminho for um arquivo ou pasta real, serve normalmente
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Qualquer outra rota cai no index.html (deixa o React Router resolver)
  RewriteRule ^ index.html [L]
</IfModule>
