# Copie para .env e ajuste conforme o ambiente
# A base das APIs (processor/auth) vem do manifest.json → src/manifest.json (dataSources).
# Em dev o caminho /api/pib passa pelo proxy do Vite; em prod, pelo proxy do Apache.

# Keycloak (login do painel administrativo)
# Em dev pode deixar vazio/relativo: "/keycloak" passa pelo proxy do Vite.
VITE_KEYCLOAK_URL=/keycloak
VITE_KEYCLOAK_REALM=sites
VITE_KEYCLOAK_CLIENT=pib
VITE_KEYCLOAK_ADMIN_ROLE=pib_admin
